{
  "name": "openclaw-node",
  "version": "0.0.5",
  "description": "Node.js client for the OpenClaw Gateway WebSocket protocol",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "ai",
    "agent",
    "websocket",
    "client",
    "llm",
    "claude",
    "chatbot",
    "automation",
    "pinchy"
  ],
  "author": {
    "name": "Clemens Helm",
    "email": "hey@clemenshelm.com",
    "url": "https://clemenshelm.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heypinchy/openclaw-node"
  },
  "homepage": "https://heypinchy.com",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/clemenshelm"
  },
  "bugs": {
    "url": "https://github.com/heypinchy/openclaw-node/issues"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "eslint": "^10.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "ws": "^8.0.0"
  }
}
